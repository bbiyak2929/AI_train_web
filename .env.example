# ============================================================
# AI Training Management Platform — Environment Variables
# Copy this file to .env and adjust values for your environment
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=aitrain
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=aitrain
DATABASE_URL=postgresql://aitrain:changeme_db_password@db:5432/aitrain

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO (S3-compatible) ──────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=aitrain

# ── JWT Auth ────────────────────────────────────────────────
JWT_SECRET_KEY=changeme_jwt_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173"]
DEBUG=true

# ── Runner Agent ────────────────────────────────────────────
RUNNER_TOKEN=changeme_runner_registration_token
RUNNER_API_URL=http://api:8000
RUNNER_ID=runner-001

# ── Docker GPU Settings (Runner) ────────────────────────────
GPU_ENABLED=false
ALLOWED_IMAGES=["pytorch/pytorch:latest","nvcr.io/nvidia/pytorch:latest"]
